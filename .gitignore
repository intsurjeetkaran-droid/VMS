# ── Dependencies ──────────────────────────────
node_modules/
**/node_modules/

# ── Environment variables ──────────────────────
# Local dev env (has secrets) — never commit
.env
.env.local
# Production env (public URL only) — safe to commit
# .env.production is intentionally NOT ignored

# ── Logs ──────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
backend/logs/*.log

# ── Build output ──────────────────────────────
dist/
build/
frontend/dist/

# ── OS files ──────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo

# ── Misc ──────────────────────────────────────
.cache/
coverage/
*.tgz

# ── Sensitive files — NEVER push these ────────
credentials.txt
details.txt
backend/.env
backend/.env.example
